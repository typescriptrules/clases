# Puerto del servidor
PORT=3001

# --- Configuración de email (Gmail) ---

# Tu dirección de correo de Gmail desde la que se enviarán los correos
MAIL_USER=tu_email@gmail.com

# Contraseña de Aplicación de 16 caracteres generada en tu cuenta de Google
# NO USES TU CONTRASEÑA NORMAL.
MAIL_PASS=contraseña_de_app_de_16_caracteres

# --- Emails de Destino ---

# Email que recibirá el correo de prueba del endpoint /api/test-email
TEST_EMAIL_RECIPIENT=destinatario_prueba@example.com

# Email que recibirá el reporte periódico del cron job
CRON_EMAIL_RECIPIENT=destinatario_cron@example.com
